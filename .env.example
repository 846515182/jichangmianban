# ============================================================
# Nexus-Panel 环境变量模板 (.env.example)
# 使用方法: 复制为 .env 并填入实际值
# 密钥生成: openssl rand -base64 32  (生成 32 字节随机密钥)
# ============================================================

# ---------- 数据库配置(PostgreSQL) ----------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=nexus
DB_PASS=nexus
DB_NAME=nexus_panel

# ---------- Redis 配置 ----------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASS=

# ---------- 安全密钥(必填) ----------
# JWT 签名密钥(使用 openssl rand -base64 32 生成)
JWT_SECRET=
# AES 主密钥(32 字节，使用 openssl rand -base64 32 生成)
AES_MASTER_KEY=
# 订阅 HMAC 签名密钥
HMAC_SUB_SECRET=

# ---------- JWT 时效(支持秒数或 duration 字符串，如 24h / 1440) ----------
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=168h

# ---------- 监听地址 ----------
HTTP_LISTEN=:8080
GRPC_LISTEN=:9090

# ---------- 限流配置(每秒请求数) ----------
RATE_USER=20
RATE_ADMIN=5
RATE_SUB=5

# ---------- 登录风控 ----------
# 最大连续失败次数
LOGIN_MAX_FAIL=5
# 锁定时长(duration 字符串)
LOGIN_LOCK_WINDOW=15m

# ---------- 订阅签名有效期 ----------
SUB_SIG_TTL=5m

# ---------- IP 黑名单时长 ----------
IP_BAN_TTL=1h

# ---------- 初始管理员 ----------
# 仅首次启动时创建默认管理员(用户名 admin)，之后修改需通过面板
ADMIN_INIT_PASSWORD=admin123
