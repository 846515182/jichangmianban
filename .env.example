# ============================================================
# Nexus-Panel 环境变量模板
# 复制为 .env 并修改所有 change-me 的值为真随机字符串
# ============================================================
# !! 生产环境密钥生成命令:
#   openssl rand -hex 64   # JWT_SECRET / HMAC_SUB_SECRET
#   openssl rand -base64 32  # AES_MASTER_KEY

# ===== 数据库 (PostgreSQL) =====
DB_HOST=postgres
DB_PORT=5432
DB_USER=nexus
DB_PASSWORD=change-me-on-first-deploy
DB_NAME=nexus_panel
DB_SSLMODE=disable

# ===== Redis =====
REDIS_ADDR=redis:6379
REDIS_PASSWORD=change-me-on-first-deploy

# ===== JWT 鉴权 =====
JWT_SECRET=
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=604800

# ===== AES 加密主密钥 =====
AES_MASTER_KEY=

# ===== 订阅签名密钥 =====
HMAC_SUB_SECRET=

# ===== 面板域名 =====
PANEL_DOMAIN=

# ===== 限频配置 =====
RATE_USER=60
RATE_ADMIN=30
RATE_SUB=10

# ===== 登录安全 =====
LOGIN_MAX_FAIL=10
LOGIN_LOCK_WINDOW=900

# ===== gRPC 节点通信 =====
GRPC_LISTEN=:50051

# ===== 可选: SMTP 邮件 =====
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_FROM_NAME=Nexus-Panel

# ===== 可选: Telegram 通知 =====
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ===== 可选: HTTPS =====
# HTTPS_LISTEN=:443
# TLS_CERT=
# TLS_KEY=

# ===== 可选: gRPC TLS =====
# GRPC_TLS_CERT=
# GRPC_TLS_KEY=
# GRPC_TLS_CA=

# ===== 运维脚本凭据 =====
OPS_NODE_HOST=127.0.0.1
OPS_NODE_SSH_PWD=
OPS_REDIS_PWD=
