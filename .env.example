# ============================================================
# Nexus-Panel 环境变量模板 (.env.example)
# 使用方法: 复制为 .env 并填入实际值
# 密钥生成: openssl rand -base64 32  (生成 32 字节随机密钥)
# ============================================================

# ---------- 数据库配置(PostgreSQL) ----------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=nexus
DB_PASS=nexus
DB_NAME=nexus_panel

# ---------- Redis 配置 ----------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASS=

# ---------- 安全密钥(必填) ----------
# JWT 签名密钥(使用 openssl rand -base64 32 生成)
JWT_SECRET=
# AES 主密钥(32 字节，使用 openssl rand -base64 32 生成)
AES_MASTER_KEY=
# 订阅 HMAC 签名密钥
HMAC_SUB_SECRET=

# ---------- JWT 时效(支持秒数或 duration 字符串，如 24h / 1440) ----------
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=168h

# ---------- 监听地址 ----------
HTTP_LISTEN=:8080
GRPC_LISTEN=:9090

# ---------- 限流配置(每秒请求数) ----------
RATE_USER=20
RATE_ADMIN=5
RATE_SUB=5

# ---------- 登录风控 ----------
# 最大连续失败次数
LOGIN_MAX_FAIL=5
# 锁定时长(duration 字符串)
LOGIN_LOCK_WINDOW=15m

# ---------- 订阅签名有效期 ----------
SUB_SIG_TTL=5m

# ---------- IP 黑名单时长 ----------
IP_BAN_TTL=1h

# ---------- 邮件服务(SMTP) ----------
# Mailtrap 推荐配置:
#   SMTP_HOST=live.smtp.mailtrap.io
#   SMTP_PORT=587
#   SMTP_USER=api
#   SMTP_PASS=<your-api-token>          (在 Mailtrap Sending Setup → SMTP 获取)
#   SMTP_FROM=noreply@your-verified-domain.com
#   SMTP_FROM_NAME=Nexus-Panel
#
# 其他 SMTP 服务商:
#   QQ邮箱:  smtp.qq.com:587    用户名=邮箱地址  密码=授权码
#   163邮箱: smtp.163.com:465   用户名=邮箱地址  密码=授权码
#   Gmail:   smtp.gmail.com:587 用户名=邮箱地址  密码=应用专用密码
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Nexus-Panel

# ---------- 面板域名(用于生成邮件中的链接) ----------
PANEL_DOMAIN=

# ---------- 初始管理员 ----------
# 仅首次启动时创建默认管理员(用户名 admin)，之后修改需通过面板
ADMIN_INIT_PASSWORD=admin123
